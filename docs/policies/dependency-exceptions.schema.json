{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shipfox.dev/schemas/dependency-exceptions.schema.json",
  "title": "Shipfox transitive dependency exceptions",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "transitiveExceptions"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "transitiveExceptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/transitiveException"
      }
    }
  },
  "$defs": {
    "transitiveException": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package",
        "allowedVersions",
        "classification",
        "reason",
        "removalCondition"
      ],
      "properties": {
        "package": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^*\\s]+$"
        },
        "allowedVersions": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?:0|[1-9]\\d*)\\.(?:0|[1-9]\\d*)\\.(?:0|[1-9]\\d*)(?:-(?:(?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
          }
        },
        "classification": {
          "enum": [
            "temporary-compatibility",
            "permanent-platform",
            "permanent-toolchain"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "removalCondition": {
          "type": "string",
          "minLength": 1
        },
        "trackingIssue": {
          "type": "string",
          "pattern": "^ENG-[1-9][0-9]*$"
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "classification": {
                "const": "temporary-compatibility"
              }
            },
            "required": ["classification"]
          },
          "then": {
            "required": ["trackingIssue", "owner"]
          }
        }
      ]
    }
  }
}
