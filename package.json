{
  "name": "@shipfox/workspace",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShipfoxHQ/shipfox.git"
  },
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:services:up && mise exec -- turbo dev --filter=@shipfox/api --filter=@shipfox/client",
    "dev:services:cleanup": "turbo build --filter=@shipfox/worktree-services... && shipfox-worktree-services cleanup",
    "dev:services:destroy": "turbo build --filter=@shipfox/worktree-services... && shipfox-worktree-services destroy",
    "dev:services:status": "turbo build --filter=@shipfox/worktree-services... && shipfox-worktree-services status",
    "dev:services:stop": "turbo build --filter=@shipfox/worktree-services... && shipfox-worktree-services stop",
    "dev:services:up": "turbo build --filter=@shipfox/worktree-services... && shipfox-worktree-services up",
    "check:dependencies": "pnpm --filter=@shipfox/dependency-policy verify:dependencies",
    "check:api-context-inventory": "turbo verify --filter=@shipfox/api-architecture-policy",
    "check:api-database-boundaries": "turbo verify --filter=@shipfox/api-database-policy",
    "check:client-architecture": "turbo verify --filter=@shipfox/client-architecture-policy",
    "check:lockfile": "turbo build --filter=@shipfox/dependency-policy && pnpm --filter=@shipfox/dependency-policy verify:lockfile",
    "check:published-artifacts": "turbo verify --filter=@shipfox/package-release",
    "fix:dependencies": "pnpm --filter=@shipfox/dependency-policy fix",
    "release:preflight": "turbo type build type:emit --filter='./libs/**' --filter='./tools/**' && pnpm --filter=@shipfox/package-release preflight",
    "release:publish": "pnpm run release:preflight && pnpm --filter=@shipfox/package-release publish:closure",
    "test:external": "turbo test:external",
    "verify": "turbo verify"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@shipfox/worktree-services": "workspace:*",
    "@types/node": "catalog:"
  }
}
