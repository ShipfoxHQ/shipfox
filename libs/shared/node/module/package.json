{
  "name": "@shipfox/node-module",
  "license": "MIT",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShipfoxHQ/shipfox.git",
    "directory": "libs/shared/node/module"
  },
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "imports": {
    "#test/*": "./test/*",
    "#*": {
      "workspace-source": "./src/*",
      "default": "./dist/*"
    }
  },
  "exports": {
    ".": {
      "workspace-source": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./inter-module": {
      "workspace-source": {
        "types": "./src/inter-module/index.ts",
        "default": "./src/inter-module/index.ts"
      },
      "default": {
        "types": "./dist/inter-module/index.d.ts",
        "default": "./dist/inter-module/index.js"
      }
    },
    "./inter-module/testing": {
      "workspace-source": {
        "types": "./src/inter-module/testing.ts",
        "default": "./src/inter-module/testing.ts"
      },
      "default": {
        "types": "./dist/inter-module/testing.d.ts",
        "default": "./dist/inter-module/testing.js"
      }
    }
  },
  "scripts": {
    "build": "shipfox-swc",
    "check": "shipfox-biome-check",
    "check:fix": "shipfox-biome-check --write",
    "test": "shipfox-vitest-run",
    "test:watch": "shipfox-vitest-watch",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit"
  },
  "dependencies": {
    "@shipfox/inter-module": "workspace:*",
    "@shipfox/node-drizzle": "workspace:*",
    "@shipfox/node-fastify": "workspace:*",
    "@shipfox/node-error-monitoring": "workspace:*",
    "@shipfox/node-opentelemetry": "workspace:*",
    "@shipfox/node-outbox": "workspace:*",
    "@shipfox/node-temporal": "workspace:*",
    "@temporalio/activity": "catalog:",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@shipfox/biome": "workspace:*",
    "@shipfox/swc": "workspace:*",
    "@shipfox/ts-config": "workspace:*",
    "@shipfox/typescript": "workspace:*",
    "@shipfox/vitest": "workspace:*"
  }
}
