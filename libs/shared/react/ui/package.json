{
  "name": "@shipfox/react-ui",
  "license": "MIT",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "imports": {
    "#test/*": "./test/*",
    "#*": "./src/*"
  },
  "style": "dist/styles.css",
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./index.css": {
      "style": "./index.css",
      "default": "./index.css"
    },
    "./dist/styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "shipfox-swc && pnpm run build:css",
    "build:css": "vite build --config vite.css.config.ts && rm -f dist/css-entry.js dist/css-entry.js.map",
    "check": "shipfox-biome-check",
    "check:fix": "shipfox-biome-check --write",
    "storybook": "storybook dev",
    "storybook:build": "storybook build -o storybook-static",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@remixicon/react": "^4.6.0",
    "@swc/helpers": "^0.5.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.575.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@shipfox/biome": "workspace:*",
    "@shipfox/swc": "workspace:*",
    "@shipfox/ts-config": "workspace:*",
    "@shipfox/typescript": "workspace:*",
    "@shipfox/vite": "workspace:*",
    "@storybook/react": "^10.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "storybook": "^10.0.0",
    "storybook-addon-pseudo-states": "^10.0.0",
    "vite": "^8.0.3"
  }
}
