{
  "name": "@shipfox/react-ui",
  "license": "MIT",
  "private": false,
  "version": "0.3.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShipfoxHQ/shipfox.git",
    "directory": "libs/shared/react/ui"
  },
  "type": "module",
  "imports": {
    "#test/*": "./test/*",
    "#*": {
      "workspace-source": "./src/*",
      "development": "./src/*",
      "default": "./dist/*"
    }
  },
  "style": "dist/styles.css",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./hooks": {
      "development": {
        "types": "./src/hooks/index.ts",
        "default": "./src/hooks/index.ts"
      },
      "default": {
        "types": "./dist/hooks/index.d.ts",
        "default": "./dist/hooks/index.js"
      }
    },
    "./utils": {
      "development": {
        "types": "./src/utils/index.ts",
        "default": "./src/utils/index.ts"
      },
      "default": {
        "types": "./dist/utils/index.d.ts",
        "default": "./dist/utils/index.js"
      }
    },
    "./index.css": {
      "style": "./index.css",
      "default": "./index.css"
    },
    "./dist/styles.css": "./dist/styles.css",
    "./hooks/*": {
      "development": {
        "types": "./src/hooks/*.ts",
        "default": "./src/hooks/*.ts"
      },
      "default": {
        "types": "./dist/hooks/*.d.ts",
        "default": "./dist/hooks/*.js"
      }
    },
    "./utils/*": {
      "development": {
        "types": "./src/utils/*.ts",
        "default": "./src/utils/*.ts"
      },
      "default": {
        "types": "./dist/utils/*.d.ts",
        "default": "./dist/utils/*.js"
      }
    },
    "./*": {
      "development": {
        "types": "./src/components/*/index.ts",
        "default": "./src/components/*/index.ts"
      },
      "default": {
        "types": "./dist/components/*/index.d.ts",
        "default": "./dist/components/*/index.js"
      }
    }
  },
  "scripts": {
    "build": "shipfox-swc --copy-files && pnpm run build:css",
    "build:css": "vite build --config vite.css.config.ts && rm -f dist/css-entry.js dist/css-entry.js.map",
    "check": "shipfox-biome-check",
    "check:fix": "shipfox-biome-check --write",
    "storybook": "storybook dev",
    "storybook:build": "storybook build -o storybook-static",
    "test": "shipfox-vitest-run",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "catalog:",
    "@radix-ui/react-avatar": "catalog:",
    "@radix-ui/react-collapsible": "catalog:",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@radix-ui/react-label": "catalog:",
    "@radix-ui/react-popover": "catalog:",
    "@radix-ui/react-radio-group": "catalog:",
    "@radix-ui/react-scroll-area": "catalog:",
    "@radix-ui/react-select": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-switch": "catalog:",
    "@radix-ui/react-tabs": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "@remixicon/react": "catalog:",
    "@swc/helpers": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "catalog:",
    "date-fns": "catalog:",
    "framer-motion": "catalog:",
    "lucide-react": "catalog:",
    "react-day-picker": "catalog:",
    "react-markdown": "catalog:",
    "rehype-sanitize": "catalog:",
    "remark-gfm": "catalog:",
    "shiki": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "vaul": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@argos-ci/cli": "catalog:",
    "@argos-ci/storybook": "catalog:",
    "@shipfox/biome": "workspace:*",
    "@shipfox/swc": "workspace:*",
    "@shipfox/ts-config": "workspace:*",
    "@shipfox/typescript": "workspace:*",
    "@shipfox/vite": "workspace:*",
    "@shipfox/vitest": "workspace:*",
    "@storybook/addon-vitest": "catalog:",
    "@storybook/react": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "jsdom": "catalog:",
    "storybook": "catalog:",
    "storybook-addon-pseudo-states": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
