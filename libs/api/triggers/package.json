{
  "name": "@shipfox/api-triggers",
  "license": "MIT",
  "version": "6.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShipfoxHQ/shipfox.git",
    "directory": "libs/api/triggers"
  },
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "imports": {
    "#test/*": "./test/*",
    "#*": {
      "workspace-source": "./src/*",
      "default": "./dist/*"
    }
  },
  "exports": {
    ".": {
      "workspace-source": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "shipfox-swc && shipfox-temporal-bundle dist/temporal/workflows/index.js",
    "check": "shipfox-biome-check",
    "check:fix": "shipfox-biome-check --write",
    "depcruise": "shipfox-depcruise",
    "test": "shipfox-vitest-run",
    "test:watch": "shipfox-vitest-watch",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit"
  },
  "dependencies": {
    "@shipfox/api-auth-context": "workspace:*",
    "@shipfox/api-definitions-dto": "workspace:*",
    "@shipfox/api-integration-core-dto": "workspace:*",
    "@shipfox/api-projects": "workspace:*",
    "@shipfox/api-triggers-dto": "workspace:*",
    "@shipfox/api-workflows-dto": "workspace:*",
    "@shipfox/config": "workspace:*",
    "@shipfox/expression": "workspace:*",
    "@shipfox/inter-module": "workspace:*",
    "@shipfox/node-drizzle": "workspace:*",
    "@shipfox/node-fastify": "workspace:*",
    "@shipfox/node-module": "workspace:*",
    "@shipfox/node-opentelemetry": "workspace:*",
    "@shipfox/node-outbox": "workspace:*",
    "@shipfox/node-postgres": "workspace:*",
    "@shipfox/node-temporal": "workspace:*",
    "@shipfox/workflow-document": "workspace:*",
    "@temporalio/workflow": "catalog:",
    "cron-parser": "catalog:",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@shipfox/biome": "workspace:*",
    "@shipfox/depcruise": "workspace:*",
    "@shipfox/swc": "workspace:*",
    "@shipfox/ts-config": "workspace:*",
    "@shipfox/typescript": "workspace:*",
    "@shipfox/vitest": "workspace:*",
    "@temporalio/activity": "catalog:",
    "@temporalio/client": "catalog:",
    "@temporalio/common": "catalog:",
    "@temporalio/testing": "catalog:",
    "@temporalio/worker": "catalog:",
    "@types/pg": "catalog:",
    "drizzle-kit": "catalog:",
    "fastify": "catalog:",
    "fastify-type-provider-zod": "catalog:",
    "fishery": "catalog:"
  }
}
