{
  "name": "@shipfox/api-workflow-language",
  "license": "MIT",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShipfoxHQ/platform.git",
    "directory": "libs/api/workflow-language"
  },
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "imports": {
    "#test/*": "./test/*",
    "#*": "./src/*"
  },
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "shipfox-swc",
    "check": "shipfox-biome-check",
    "check:fix": "shipfox-biome-check --write",
    "depcruise": "shipfox-depcruise",
    "generate:docs": "node --import tsx scripts/generate-formalization-docs.ts",
    "test": "shipfox-vitest-run",
    "test:watch": "shipfox-vitest-watch",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shipfox/biome": "workspace:*",
    "@shipfox/depcruise": "workspace:*",
    "@shipfox/swc": "workspace:*",
    "@shipfox/ts-config": "workspace:*",
    "@shipfox/typescript": "workspace:*",
    "@shipfox/vitest": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "tsx": "^4.21.0"
  }
}
