{
  "name": "simple build",
  "triggers": {
    "main_push": {
      "source": "github_acme",
      "event": "push",
      "filter": "event.ref == \"refs/heads/main\""
    }
  },
  "jobs": {
    "build": {
      "steps": [
        {
          "run": "npm install"
        },
        {
          "name": "build",
          "run": "npm run build",
          "gate": {
            "success_if": "exit_code == 0"
          }
        }
      ]
    }
  }
}
