{
  "name": "@shipfox/client-invitations",
  "license": "MIT",
  "version": "0.0.5",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShipfoxHQ/shipfox.git",
    "directory": "libs/client/invitations"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "imports": {
    "#*": {
      "types": "./src/*",
      "workspace-source": "./src/*",
      "development": "./src/*",
      "default": "./dist/*"
    },
    "#test/*": "./test/*"
  },
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./feature": {
      "development": {
        "types": "./src/feature.ts",
        "default": "./src/feature.ts"
      },
      "default": {
        "types": "./dist/feature.d.ts",
        "default": "./dist/feature.js"
      }
    },
    "./routes/*": {
      "development": {
        "types": "./src/routes/*.tsx",
        "default": "./src/routes/*.tsx"
      },
      "default": {
        "types": "./dist/routes/*.d.ts",
        "default": "./dist/routes/*.js"
      }
    }
  },
  "scripts": {
    "build": "shipfox-swc",
    "check": "shipfox-biome-check",
    "check:fix": "shipfox-biome-check --write",
    "test": "shipfox-vitest-run",
    "test:watch": "shipfox-vitest-watch",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit"
  },
  "dependencies": {
    "@shipfox/api-auth-dto": "workspace:*",
    "@shipfox/api-workspaces-dto": "workspace:*",
    "@shipfox/client-api": "workspace:*",
    "@shipfox/client-auth": "workspace:*",
    "@shipfox/client-shell": "workspace:*",
    "@shipfox/react-ui": "workspace:*",
    "@swc/helpers": "catalog:",
    "@tanstack/react-query": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@shipfox/biome": "workspace:*",
    "@shipfox/client-test-setup": "workspace:*",
    "@shipfox/swc": "workspace:*",
    "@shipfox/ts-config": "workspace:*",
    "@shipfox/typescript": "workspace:*",
    "@shipfox/vite": "workspace:*",
    "@shipfox/vitest": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
