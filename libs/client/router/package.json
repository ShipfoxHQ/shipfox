{
  "name": "@shipfox/client-router",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "vite-build",
    "check": "shipfox-biome-check",
    "check:fix": "shipfox-biome-check --write",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit"
  },
  "dependencies": {
    "@shipfox/client-api": "workspace:*",
    "@shipfox/client-app-shell": "workspace:*",
    "@shipfox/client-auth": "workspace:*",
    "@shipfox/client-integrations": "workspace:*",
    "@shipfox/client-projects": "workspace:*",
    "@shipfox/react-ui": "workspace:*",
    "@swc/helpers": "^0.5.17",
    "@tanstack/react-router": "^1.168.25",
    "jotai": "^2.19.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@shipfox/biome": "workspace:*",
    "@shipfox/ts-config": "workspace:*",
    "@shipfox/typescript": "workspace:*",
    "@shipfox/vite": "workspace:*",
    "@tanstack/router-plugin": "^1.167.28",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^8.0.3"
  }
}
