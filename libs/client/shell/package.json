{
  "name": "@shipfox/client-shell",
  "license": "MIT",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShipfoxHQ/shipfox.git",
    "directory": "libs/client/shell"
  },
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "imports": {
    "#*": {
      "workspace-source": "./src/*",
      "development": "./src/*",
      "default": "./dist/*"
    },
    "#test/*": "./test/*"
  },
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./runtime": {
      "development": {
        "types": "./src/runtime/index.ts",
        "default": "./src/runtime/index.ts"
      },
      "default": {
        "types": "./dist/runtime/index.d.ts",
        "default": "./dist/runtime/index.js"
      }
    },
    "./testing": {
      "development": {
        "types": "./src/testing/index.tsx",
        "default": "./src/testing/index.tsx"
      },
      "default": {
        "types": "./dist/testing/index.d.ts",
        "default": "./dist/testing/index.js"
      }
    },
    "./vite": {
      "development": {
        "types": "./src/vite/index.ts",
        "default": "./src/vite/index.ts"
      },
      "default": {
        "types": "./dist/vite/index.d.ts",
        "default": "./dist/vite/index.js"
      }
    }
  },
  "scripts": {
    "build": "shipfox-swc",
    "check": "shipfox-biome-check",
    "check:fix": "shipfox-biome-check --write",
    "test": "shipfox-vitest-run",
    "test:watch": "shipfox-vitest-watch",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit"
  },
  "dependencies": {
    "@shipfox/api-auth-dto": "workspace:*",
    "@shipfox/api-workspaces-dto": "workspace:*",
    "@shipfox/client-api": "workspace:*",
    "@shipfox/client-config": "workspace:*",
    "@shipfox/react-ui": "workspace:*",
    "@swc/helpers": "catalog:",
    "@tanstack/router-core": "catalog:",
    "jiti": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.16",
    "jotai": "^2.19.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "@shipfox/biome": "workspace:*",
    "@shipfox/client-test-setup": "workspace:*",
    "@shipfox/swc": "workspace:*",
    "@shipfox/ts-config": "workspace:*",
    "@shipfox/typescript": "workspace:*",
    "@shipfox/vitest": "workspace:*",
    "@storybook/react": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jotai": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:"
  }
}
