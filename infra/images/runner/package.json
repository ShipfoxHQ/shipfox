{
  "name": "@shipfox/runner-image",
  "license": "MIT",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "bin": {
    "build-runner-image": "./bin/build-runner-image.js",
    "runner-image-catalog": "./bin/runner-image-catalog.js"
  },
  "scripts": {
    "build": "shipfox-swc",
    "check": "shipfox-biome-check",
    "check:fix": "shipfox-biome-check --write",
    "image:build": "node ./bin/build-runner-image.js ubuntu24 aws",
    "test": "shipfox-vitest-run",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit"
  },
  "dependencies": {
    "@shipfox/runner": "workspace:*",
    "ajv": "catalog:",
    "ajv-formats": "catalog:"
  },
  "devDependencies": {
    "@shipfox/biome": "workspace:*",
    "@shipfox/swc": "workspace:*",
    "@shipfox/tool-utils": "workspace:*",
    "@shipfox/ts-config": "workspace:*",
    "@shipfox/typescript": "workspace:*",
    "@shipfox/vitest": "workspace:*"
  }
}
