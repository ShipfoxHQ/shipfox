# Shared local-development configuration (committed). Per-developer overrides go
# in .env.local (gitignored).

# Object storage for runner logs — points at the bundled Garage (compose.yml).
# Run `docker compose up -d garage && ./dev/garage/bootstrap.sh` once to create
# the bucket and key these values reference.
LOG_STORAGE_S3_ENDPOINT=http://localhost:3900
LOG_STORAGE_S3_REGION=garage
LOG_STORAGE_S3_BUCKET=shipfox-logs
LOG_STORAGE_S3_ACCESS_KEY_ID=GKc0ffeec0ffeec0ffeec0ffee
LOG_STORAGE_S3_SECRET_ACCESS_KEY=c0ffeec0ffeec0ffeec0ffeec0ffeec0ffeec0ffeec0ffeec0ffeec0ffeec0ff
LOG_STORAGE_S3_FORCE_PATH_STYLE=true
