{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ShipfoxHQ/shipfox/blob/main/tools/architecture-policy/schema/rule-catalog.schema.json",
  "title": "Shipfox architecture policy rule catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "rules"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "description", "guidanceLocation", "blocking"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "guidanceLocation": { "type": "string", "minLength": 1 },
          "blocking": { "const": true }
        }
      }
    }
  }
}
