{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:shipfox:schema:publication-closure",
  "title": "Shipfox publication closure",
  "type": "object",
  "additionalProperties": false,
  "required": ["roots", "packages"],
  "properties": {
    "$schema": { "type": "string" },
    "roots": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/packageName" }
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/packageName" }
    }
  },
  "$defs": {
    "packageName": {
      "type": "string",
      "pattern": "^@shipfox/[a-z0-9][a-z0-9._-]*$"
    }
  }
}
