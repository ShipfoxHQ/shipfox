{
  "name": "@shipfox/api-database-policy",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "shipfox-swc",
    "check": "shipfox-biome-check",
    "check:fix": "shipfox-biome-check --write",
    "test": "shipfox-vitest-run",
    "test:watch": "shipfox-vitest-watch",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit",
    "verify": "cd ../.. && node tools/biome/bin/biome-check.js --config-path biome.json libs/api && node tools/api-database-policy/dist/api-database-registry.js && node tools/api-database-policy/dist/api-database-boundaries.js",
    "verify:boundaries": "node dist/api-database-boundaries.js",
    "verify:catalog": "node dist/api-database-catalog.js"
  },
  "dependencies": {
    "@shipfox/node-drizzle": "workspace:*",
    "@shipfox/node-postgres": "workspace:*"
  },
  "devDependencies": {
    "@shipfox/biome": "workspace:*",
    "@shipfox/swc": "workspace:*",
    "@shipfox/ts-config": "workspace:*",
    "@shipfox/typescript": "workspace:*",
    "@shipfox/vitest": "workspace:*",
    "@types/node": "catalog:"
  }
}
