{
  "name": "@shipfox/engineering-guidance",
  "version": "1.0.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShipfoxHQ/shipfox.git",
    "directory": "tools/engineering-guidance"
  },
  "license": "MIT",
  "private": false,
  "type": "module",
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/manifest.js",
    "dist/manifest.d.ts",
    "dist/bundle",
    "schema"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "shipfox-swc && node dist/generate.js --build && shipfox-tsc-emit",
    "prepack": "node dist/generate.js --ensure",
    "check": "shipfox-biome-check",
    "check:fix": "shipfox-biome-check --write",
    "test": "shipfox-vitest-run",
    "test:watch": "shipfox-vitest-watch",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit",
    "verify": "node dist/generate.js --verify"
  },
  "devDependencies": {
    "@shipfox/biome": "workspace:*",
    "@shipfox/repository-documentation-policy": "workspace:*",
    "@shipfox/swc": "workspace:*",
    "@shipfox/ts-config": "workspace:*",
    "@shipfox/typescript": "workspace:*",
    "@shipfox/vitest": "workspace:*",
    "@types/node": "catalog:"
  }
}
