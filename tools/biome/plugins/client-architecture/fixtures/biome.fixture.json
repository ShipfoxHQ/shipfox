{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": false
  },
  "assist": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "useEditorconfig": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "plugins": [
    {
      "path": "../fixture-boundary.grit",
      "includes": [
        "**/*.ts",
        "!**/*.test.ts",
        "!**/*.stories.ts",
        "!**/test/**",
        "!**/tests/**",
        "!**/__tests__/**",
        "!**/generated/**",
        "!**/__generated__/**",
        "!**/*.gen.ts"
      ]
    }
  ],
  "files": {
    "includes": [
      "**/*.ts",
      "!**/*.test.ts",
      "!**/*.stories.ts",
      "!**/test/**",
      "!**/tests/**",
      "!**/__tests__/**",
      "!**/generated/**",
      "!**/__generated__/**",
      "!**/*.gen.ts"
    ]
  }
}
