{
  "name": "@shipfox/runner",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShipfoxHQ/shipfox.git",
    "directory": "apps/runner"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "shipfox-swc",
    "dev": "tsx watch --conditions=workspace-source --env-file-if-exists=.env --env-file-if-exists=.env.local src/index.ts",
    "image": "shipfox-docker --setup-context --image runner",
    "check": "shipfox-biome-check",
    "check:fix": "shipfox-biome-check --write",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit"
  },
  "dependencies": {
    "@shipfox/node-opentelemetry": "workspace:*",
    "@shipfox/runner-orchestration": "workspace:*"
  },
  "devDependencies": {
    "@shipfox/biome": "workspace:*",
    "@shipfox/docker": "workspace:*",
    "@shipfox/swc": "workspace:*",
    "@shipfox/ts-config": "workspace:*",
    "@shipfox/typescript": "workspace:*",
    "tsx": "catalog:"
  }
}
