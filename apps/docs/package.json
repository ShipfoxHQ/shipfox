{
  "name": "@shipfox/docs",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShipfoxHQ/shipfox.git",
    "directory": "apps/docs"
  },
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpm generate && next build",
    "check": "shipfox-biome-check",
    "check:fix": "shipfox-biome-check --write",
    "dev": "pnpm generate && next dev --turbo --port ${SHIPFOX_DOCS_PORT:-3500}",
    "start": "next start --port ${SHIPFOX_DOCS_PORT:-3500}",
    "type": "shipfox-tsc-check",
    "generate": "tsx --conditions=development scripts/generate.mjs",
    "test": "pnpm generate && pnpm test:unit && tsx scripts/check-writing.mjs && tsx scripts/check-links.mjs && tsx scripts/check-workflow-schema.mjs && tsx scripts/check-catalog.mjs",
    "test:unit": "tsx --test",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@shipfox/workflow-document": "workspace:*",
    "fumadocs-core": "16.7.10",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.7.10",
    "lucide-react": "^1.0.0",
    "next": "16.2.3",
    "next-themes": "0.4.6",
    "posthog-js": "^1.256.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "simple-icons": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shipfox/api-agent-dto": "workspace:*",
    "@shipfox/api-integration-core-dto": "workspace:*",
    "@shipfox/api-integration-github-dto": "workspace:*",
    "@shipfox/api-integration-sentry-dto": "workspace:*",
    "@shipfox/api-integration-webhook-dto": "workspace:*",
    "@shipfox/biome": "workspace:*",
    "@shipfox/ts-config": "workspace:*",
    "@shipfox/typescript": "workspace:*",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/mdx": "^2.0.13",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "github-slugger": "^2.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.21.0"
  }
}
