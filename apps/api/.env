# Fastify
PORT=16101
HOST=127.0.0.1

# E2E
E2E_ENABLED=true
E2E_ADMIN_API_KEY=e2e-admin-api-key

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Client
CLIENT_BASE_URL=http://localhost:5173

# Workspaces / auth
AUTH_JWT_SECRET=dev-only-jwt-secret-change-me
AUTH_JWT_EXPIRES_IN=15m

# Job lease capability token (job-scoped, HS256) — minted by Scheduling, verified by Orchestration
AUTH_JOB_LEASE_TOKEN_SECRET=dev-only-lease-secret-change-me
# AUTH_JOB_LEASE_TOKEN_EXPIRES_IN=90m

# Mailer (console = log to stdout, smtp = real SMTP)
MAILER_TRANSPORT=console
MAILER_FROM=noreply@shipfox.local
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Integrations
INTEGRATIONS_ENABLE_DEBUG_PROVIDER=true
INTEGRATIONS_ENABLE_GITHUB_PROVIDER=false
# Add your GitHub App credentials to the following variables.
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# GITHUB_APP_WEBHOOK_SECRET=
# GITHUB_APP_SLUG=
# Generate a random secret for the GitHub install state secret. `openssl rand -hex 32`
# GITHUB_INSTALL_STATE_SECRET=
