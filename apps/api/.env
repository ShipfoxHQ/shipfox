# Fastify
PORT=16101
HOST=127.0.0.1

# E2E
E2E_ENABLED=true
E2E_ADMIN_API_KEY=e2e-admin-api-key

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Client
CLIENT_BASE_URL=http://localhost:5173

# Workspaces / auth
AUTH_JWT_SECRET=dev-only-jwt-secret-change-me
AUTH_JWT_EXPIRES_IN=15m

# Job lease capability token (job-scoped, HS256) — minted by Scheduling, verified by Orchestration
AUTH_JOB_LEASE_TOKEN_SECRET=dev-only-lease-secret-change-me
# AUTH_JOB_LEASE_TOKEN_EXPIRES_IN=90m

# Mailer (console = log to stdout, smtp = real SMTP)
MAILER_TRANSPORT=console
MAILER_FROM=noreply@shipfox.local
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Integrations
INTEGRATIONS_ENABLE_DEBUG_PROVIDER=true

# Gitea — points at the bundled Gitea (compose.yml), seeded by gitea-init.
# See dev/gitea/README.md. The service username/token are the bot the bootstrap
# creates; the token is the bot password used for Basic auth.
INTEGRATIONS_ENABLE_GITEA_PROVIDER=true
GITEA_BASE_URL=http://localhost:3000
GITEA_SERVICE_USERNAME=shipfox-bot
GITEA_SERVICE_TOKEN=shipfox-bot-dev-password
GITEA_WEBHOOK_SECRET=shipfox-gitea-dev-webhook-secret
# Gitea delivers webhooks from inside its container, so the target is the host
# (host.docker.internal on Docker Desktop), not localhost.
GITEA_WEBHOOK_TARGET_URL=http://host.docker.internal:16101/webhooks/integrations/gitea

INTEGRATIONS_ENABLE_GITHUB_PROVIDER=false
# Add your GitHub App credentials to the following variables.
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# GITHUB_APP_WEBHOOK_SECRET=
# GITHUB_APP_SLUG=
# Generate a random secret for the GitHub install state secret. `openssl rand -hex 32`
# GITHUB_INSTALL_STATE_SECRET=

INTEGRATIONS_ENABLE_SENTRY_PROVIDER=false
# Add your Sentry App credentials to the following variables.
# SENTRY_APP_CLIENT_ID=
# SENTRY_APP_CLIENT_SECRET=
# SENTRY_APP_SLUG=
# SENTRY_APP_VERIFY_INSTALL=true
# Days a verified-but-unclaimed install may sit before the daily cleanup cron tombstones it (minimum 1).
# SENTRY_UNCLAIMED_INSTALLATION_RETENTION_DAYS=7
