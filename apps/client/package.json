{
  "name": "@shipfox/client",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShipfoxHQ/shipfox.git",
    "directory": "apps/client"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run generate && vite-build",
    "check": "shipfox-biome-check",
    "check:fix": "shipfox-biome-check --write",
    "dev": "pnpm run generate:dev && vite-dev",
    "generate": "node scripts/generate-client-composition.mjs",
    "generate:dev": "node --conditions=workspace-source --import=tsx scripts/generate-client-composition.mjs",
    "image": "shipfox-docker --image client",
    "type": "pnpm run generate && shipfox-tsc-check",
    "type:emit": "pnpm run generate && shipfox-tsc-emit"
  },
  "dependencies": {
    "@shipfox/client-features": "workspace:*",
    "@shipfox/client-shell": "workspace:*",
    "@shipfox/client-agent": "workspace:*",
    "@shipfox/client-auth": "workspace:*",
    "@shipfox/client-integrations": "workspace:*",
    "@shipfox/client-invitations": "workspace:*",
    "@shipfox/client-onboarding": "workspace:*",
    "@shipfox/client-projects": "workspace:*",
    "@shipfox/client-runners": "workspace:*",
    "@shipfox/client-secrets": "workspace:*",
    "@shipfox/client-triggers": "workspace:*",
    "@shipfox/client-workflows": "workspace:*",
    "@shipfox/client-workspace-settings": "workspace:*",
    "@shipfox/react-ui": "workspace:*",
    "@swc/helpers": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "jotai": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@shipfox/biome": "workspace:*",
    "@shipfox/docker": "workspace:*",
    "@shipfox/ts-config": "workspace:*",
    "@shipfox/typescript": "workspace:*",
    "@shipfox/vite": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "tailwindcss": "catalog:",
    "tsx": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "vite": "catalog:"
  }
}
